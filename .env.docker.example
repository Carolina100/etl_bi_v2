# ============================================================================
# AIRBYTE
# Usado pelo Airflow para disparar e monitorar syncs via API do Airbyte
# ============================================================================
AIRBYTE_API_URL=http://host.docker.internal:8000/api/public/v1
AIRBYTE_API_TOKEN=
AIRBYTE_CONNECTION_ID=

# ============================================================================
# SNOWFLAKE
# Usado pelo dbt e pelas tasks de orquestracao que precisam acessar o DW
# ============================================================================
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PRIVATE_KEY_PATH=/opt/airflow/project/secrets/snowflake/ETL_KEYPAIR.p8
SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=SOLIX_BI
SNOWFLAKE_SCHEMA=DS
SNOWFLAKE_ROLE_DBT=
